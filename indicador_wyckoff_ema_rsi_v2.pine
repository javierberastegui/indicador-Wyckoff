//@version=5
indicator("Indicador Wyckoff + EMA + RSI v2.6.0 DayTrading", shorttitle="Wyckoff EMA RSI v2", overlay=true, max_labels_count=500, max_lines_count=200)

// =====================================================
// Inputs visibles minimos
// =====================================================

// Filtros opcionales
usarVolumen = input.bool(false, "Activar confirmacion por volumen", group="Filtros opcionales")
volLen = input.int(20, "Media volumen", minval=1, group="Filtros opcionales")
exigirAbsorcion = input.bool(false, "Exigir absorcion/divergencia favorable", group="Filtros opcionales")
exigirManosFuertes = input.bool(false, "Exigir manos fuertes/absorcion", group="Filtros opcionales")

// Fractalidad day trading
exigirFractalidadDayTrading = input.bool(true, "Exigir sincronia 1D/1H/5m", group="Fractalidad day trading")
exigirGraficoEntrada5m = input.bool(true, "Exigir grafico 5m para señales", group="Fractalidad day trading")
mostrarFractalidadDayTrading = input.bool(false, "Mostrar etiquetas DT", group="Fractalidad day trading")
mostrarManosFuertes = input.bool(false, "Mostrar etiquetas manos fuertes", group="Fractalidad day trading")

// Visualizacion
mostrarDivergencias = input.bool(false, "Mostrar divergencias", group="Visualizacion")
mostrarAbsorciones = input.bool(false, "Mostrar absorciones", group="Visualizacion")
mostrarCinta = input.bool(false, "Mostrar cinta de tendencia", group="Visualizacion")
mostrarPanel = input.bool(true, "Mostrar panel day trading", group="Visualizacion")
mostrarCrucesEma = input.bool(false, "Mostrar cruces EMA", group="Visualizacion")
mostrarZonasWyckoff = input.bool(false, "Mostrar zonas Wyckoff", group="Visualizacion")
mostrarRetrocesos = input.bool(false, "Mostrar retrocesos PB", group="Visualizacion")
mostrarTextoDivAbsOverlay = input.bool(false, "Mostrar texto DIV/ABS en overlay", group="Visualizacion")
mostrarNombreZonaWyckoff = input.bool(false, "Mostrar nombre zona Wyckoff al cambiar", group="Visualizacion")

// Estilo EMAs
mostrarEmaOperativa = input.bool(false, "Mostrar EMA rapida/lenta", group="Estilo EMAs")
mostrarEmaMedia = input.bool(false, "Mostrar EMA media", group="Estilo EMAs")
mostrarEma50 = input.bool(true, "Mostrar EMA 50", group="Estilo EMAs")
mostrarEma200 = input.bool(false, "Mostrar EMA 200", group="Estilo EMAs")
colorEmaRapida = input.color(color.green, "Color EMA rapida", group="Estilo EMAs")
colorEmaMedia = input.color(color.orange, "Color EMA media", group="Estilo EMAs")
colorEmaLenta = input.color(color.red, "Color EMA lenta", group="Estilo EMAs")
colorEma50 = input.color(color.yellow, "Color EMA 50 filtro fuerte", group="Estilo EMAs")
colorEma200 = input.color(color.blue, "Color EMA 200", group="Estilo EMAs")
grosorEmaRapida = input.int(2, "Grosor EMA rapida", minval=1, maxval=5, group="Estilo EMAs")
grosorEmaMedia = input.int(1, "Grosor EMA media", minval=1, maxval=5, group="Estilo EMAs")
grosorEmaLenta = input.int(2, "Grosor EMA lenta", minval=1, maxval=5, group="Estilo EMAs")
grosorEma50 = input.int(2, "Grosor EMA 50", minval=1, maxval=5, group="Estilo EMAs")
grosorEma200 = input.int(2, "Grosor EMA 200", minval=1, maxval=5, group="Estilo EMAs")
transpEmaRapida = input.int(0, "Transparencia EMA rapida", minval=0, maxval=100, group="Estilo EMAs")
transpEmaMedia = input.int(0, "Transparencia EMA media", minval=0, maxval=100, group="Estilo EMAs")
transpEmaLenta = input.int(0, "Transparencia EMA lenta", minval=0, maxval=100, group="Estilo EMAs")
transpEma50 = input.int(0, "Transparencia EMA 50", minval=0, maxval=100, group="Estilo EMAs")
transpEma200 = input.int(0, "Transparencia EMA 200", minval=0, maxval=100, group="Estilo EMAs")

// Soporte / resistencia opcional y limpio
mostrarSoporteResistencia = input.bool(false, "Mostrar soporte/resistencia", group="Soporte / resistencia")

// =====================================================
// Configuracion interna fija
// =====================================================

ema200SlopeLookback = 10
ema50SlopeLookback = 5
slopeLookback = 3
atrLen = 14
divLookback = 8
sepMinAtr = 0.5
avisoLookback = 5
usarRetroceso = true
slDebil = 1.0
tpDebil = 2.0
slFuerte = 2.0
tpFuerte = 4.0
cierreParcialPct = 80
modoEtiquetas = "Compacto"
pivotLen = 5
maxLineasSR = 4
distanciaMinimaSrAtr = 0.8
mostrarSoloSrCercano = true
distanciaSrVisibleAtr = 8.0
fractalLateralLookback = 24
ratioLateralFractalMax = 5.5
volClimaxMult = 1.5
rangoCompresionAtr = 0.9

// =====================================================
// Modo automatico por timeframe
// =====================================================

tfMin = timeframe.in_seconds() / 60
string emaMode = tfMin <= 5 ? "5/8/13" : tfMin <= 15 ? "9/21" : "10/20"
int rsiLen = 14
int lateralLookback = tfMin <= 5 ? 14 : tfMin <= 15 ? 18 : 24
float ratioLateralMax = tfMin <= 5 ? 3.8 : tfMin <= 15 ? 4.5 : 5.5
emaModeInfo = emaMode == "5/8/13" ? 5813 : emaMode == "9/21" ? 921 : 1020
esGraficoEntrada5m = timeframe.isminutes and timeframe.multiplier == 5
graficoEntradaOk = not exigirGraficoEntrada5m or esGraficoEntrada5m

// =====================================================
// Calculos base
// =====================================================

ema5 = ta.ema(close, 5)
ema8 = ta.ema(close, 8)
ema9 = ta.ema(close, 9)
ema10 = ta.ema(close, 10)
ema13 = ta.ema(close, 13)
ema20 = ta.ema(close, 20)
ema21 = ta.ema(close, 21)
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

emaFast = emaMode == "9/21" ? ema9 : emaMode == "10/20" ? ema10 : ema5
emaSlow = emaMode == "9/21" ? ema21 : emaMode == "10/20" ? ema20 : ema13

rsi = ta.rsi(close, rsiLen)
rsiSlope = rsi - rsi[slopeLookback]
atr = ta.atr(atrLen)
volBase = ta.sma(volume, volLen)
volOk = not usarVolumen or volume > volBase

rangoMax = ta.highest(high, lateralLookback)
rangoMin = ta.lowest(low, lateralLookback)
rangoN = rangoMax - rangoMin
ratioRangoAtr = atr > 0 ? rangoN / atr : na
mercadoLateral = ratioRangoAtr <= ratioLateralMax

ema200Slope = ema200 - ema200[ema200SlopeLookback]
ema50Slope = ema50 - ema50[ema50SlopeLookback]
trendLong = close > ema200 and ema200Slope > 0
trendShort = close < ema200 and ema200Slope < 0
ema50LongOk = close > ema50 and ema50Slope > 0
ema50ShortOk = close < ema50 and ema50Slope < 0
estructuraLong = trendLong and ema50LongOk
estructuraShort = trendShort and ema50ShortOk

precioNuevoMin = low < ta.lowest(low[1], divLookback)
precioNuevoMax = high > ta.highest(high[1], divLookback)
rsiMinPrev = ta.lowest(rsi[1], divLookback)
rsiMaxPrev = ta.highest(rsi[1], divLookback)

divBull = precioNuevoMin and rsi > rsiMinPrev
divBear = precioNuevoMax and rsi < rsiMaxPrev

velaMitad = low + (high - low) * 0.5
absorcionBull = precioNuevoMin and rsi > rsiMinPrev and close > velaMitad
absorcionBear = precioNuevoMax and rsi < rsiMaxPrev and close < velaMitad

// =====================================================
// Manos fuertes: esfuerzo vs resultado + barridas/absorcion
// =====================================================

rangoVela = math.max(high - low, syminfo.mintick)
posicionCierre = (close - low) / rangoVela
volClimax = volume > volBase * volClimaxMult
rangoComprimido = rangoVela <= atr * rangoCompresionAtr
rechazoBajo = precioNuevoMin and close > velaMitad and posicionCierre >= 0.60
rechazoAlto = precioNuevoMax and close < velaMitad and posicionCierre <= 0.40

manosFuertesLong = absorcionBull or (volClimax and rechazoBajo) or (volClimax and rangoComprimido and close > open and posicionCierre >= 0.65)
manosFuertesShort = absorcionBear or (volClimax and rechazoAlto) or (volClimax and rangoComprimido and close < open and posicionCierre <= 0.35)

// =====================================================
// Fases Wyckoff simplificadas
// =====================================================

esAcumulacion = mercadoLateral and close <= ema200
esDistribucion = mercadoLateral and close > ema200
esMarkup = not mercadoLateral and trendLong
esMarkdown = not mercadoLateral and trendShort

fase = esAcumulacion ? "Acumulacion" : esDistribucion ? "Distribucion" : esMarkup ? "Markup" : esMarkdown ? "Markdown" : "Transicion"
faseOperativa = esAcumulacion ? "Acumulacion" : esDistribucion ? "Distribucion" : esMarkup ? "Impulso alcista" : esMarkdown ? "Impulso bajista" : "Transicion"

rupturaAcumulacion = esMarkup and esAcumulacion[1]
rupturaDistribucion = esMarkdown and esDistribucion[1]

// =====================================================
// Fractalidad day trading 1D / 1H / 5m
// =====================================================

f_estadoFractal() =>
    _ema50 = ta.ema(close, 50)
    _ema200 = ta.ema(close, 200)
    _ema50Slope = _ema50 - _ema50[ema50SlopeLookback]
    _ema200Slope = _ema200 - _ema200[ema200SlopeLookback]
    _rsi = ta.rsi(close, rsiLen)
    _rsiSlope = _rsi - _rsi[slopeLookback]
    _atr = ta.atr(atrLen)
    _rangoMax = ta.highest(high, fractalLateralLookback)
    _rangoMin = ta.lowest(low, fractalLateralLookback)
    _ratioRangoAtr = _atr > 0 ? (_rangoMax - _rangoMin) / _atr : na
    _mercadoLateral = _ratioRangoAtr <= ratioLateralFractalMax
    _trendLong = close > _ema200 and _ema200Slope > 0
    _trendShort = close < _ema200 and _ema200Slope < 0
    _ema50Long = close > _ema50 and _ema50Slope > 0
    _ema50Short = close < _ema50 and _ema50Slope < 0
    _rsiLong = _rsi > 50 and _rsiSlope > 0
    _rsiShort = _rsi < 50 and _rsiSlope < 0
    _dir = _trendLong and _ema50Long and _rsiLong and not _mercadoLateral ? 1 : _trendShort and _ema50Short and _rsiShort and not _mercadoLateral ? -1 : 0
    _ema50Dir = _ema50Long ? 1 : _ema50Short ? -1 : 0
    _faseCode = _mercadoLateral and close <= _ema200 ? 1 : _mercadoLateral and close > _ema200 ? 2 : not _mercadoLateral and _trendLong ? 3 : not _mercadoLateral and _trendShort ? -3 : 0
    _sesgo = _dir == 1 ? 1 : _dir == -1 ? -1 : _trendLong or (close > _ema200 and _ema50Long) ? 2 : _trendShort or (close < _ema200 and _ema50Short) ? -2 : 0
    [_dir, _ema50Dir, _faseCode, _rsi, _ratioRangoAtr, _sesgo]

[dirD, ema50D, faseD, rsiD, ratioD, sesgoD] = request.security(syminfo.tickerid, "D", f_estadoFractal(), barmerge.gaps_off, barmerge.lookahead_off)
[dirH1, ema50H1, faseH1, rsiH1, ratioH1, sesgoH1] = request.security(syminfo.tickerid, "60", f_estadoFractal(), barmerge.gaps_off, barmerge.lookahead_off)
[dirM5, ema50M5, faseM5, rsiM5, ratioM5, sesgoM5] = request.security(syminfo.tickerid, "5", f_estadoFractal(), barmerge.gaps_off, barmerge.lookahead_off)

macroLongOk = sesgoD > 0
macroShortOk = sesgoD < 0
lupaLongOk = sesgoH1 > 0
lupaShortOk = sesgoH1 < 0
pistolaLongOk = dirM5 == 1
pistolaShortOk = dirM5 == -1

dayTradingLongOk = macroLongOk and lupaLongOk and pistolaLongOk
dayTradingShortOk = macroShortOk and lupaShortOk and pistolaShortOk
dayTradingNeutro = not dayTradingLongOk and not dayTradingShortOk
dayTradingDireccion = dayTradingLongOk ? "DT LONG" : dayTradingShortOk ? "DT SHORT" : "ESPERAR"
fractalEntradaLongOk = not exigirFractalidadDayTrading or dayTradingLongOk
fractalEntradaShortOk = not exigirFractalidadDayTrading or dayTradingShortOk

fmtSesgo(sesgo) =>
    sesgo == 1 ? "ALCISTA" : sesgo == -1 ? "BAJISTA" : sesgo == 2 ? "Alcista flojo" : sesgo == -2 ? "Bajista flojo" : "SIN SESGO"

colorSesgo(sesgo) =>
    sesgo == 1 ? color.new(color.green, 0) : sesgo == -1 ? color.new(color.red, 0) : sesgo == 2 ? color.new(color.green, 55) : sesgo == -2 ? color.new(color.red, 55) : color.new(color.gray, 0)

fmtTf(tfMinActual) =>
    tfMinActual >= 10080 ? str.tostring(tfMinActual / 10080, "#") + "W" : tfMinActual >= 1440 ? str.tostring(tfMinActual / 1440, "#") + "D" : tfMinActual >= 60 ? str.tostring(tfMinActual / 60, "#") + "H" : str.tostring(tfMinActual, "#") + "m"

rsiLectura(valor) =>
    valor >= 70 ? "Sobrecompra" : valor <= 30 ? "Sobreventa" : valor > 55 ? "Fuerza alcista" : valor < 45 ? "Fuerza bajista" : "Neutral"

// =====================================================
// Fuerza de tendencia (divergencia = AVISO, no bloqueo)
// =====================================================

// Separacion de EMAs normalizada por ATR: mide conviccion de la tendencia
emaGap = atr > 0 ? math.abs(emaFast - emaSlow) / atr : 0.0
emaSeparadas = emaGap >= sepMinAtr

// La divergencia contraria solo "avisa" durante unas barras
bsDivBear = ta.barssince(divBear)
bsDivBull = ta.barssince(divBull)
avisoContraLong = not na(bsDivBear) and bsDivBear <= avisoLookback
avisoContraShort = not na(bsDivBull) and bsDivBull <= avisoLookback

// Tendencia fuerte = direccion clara + EMA50 + EMAs separadas + sin aviso contrario + puerta day trading sincronizada si se exige
tendenciaFuerteLong = estructuraLong and emaSeparadas and not avisoContraLong and fractalEntradaLongOk and graficoEntradaOk
tendenciaFuerteShort = estructuraShort and emaSeparadas and not avisoContraShort and fractalEntradaShortOk and graficoEntradaOk
tendenciaDebilLong = estructuraLong and not tendenciaFuerteLong
tendenciaDebilShort = estructuraShort and not tendenciaFuerteShort

direccion = estructuraLong ? "ALCISTA" : estructuraShort ? "BAJISTA" : "SIN TENDENCIA"
fuerza = (tendenciaFuerteLong or tendenciaFuerteShort) ? "FUERTE" : (tendenciaDebilLong or tendenciaDebilShort) ? "DEBIL" : "-"

// =====================================================
// Disparadores: cruce de EMAs o retroceso a la EMA rapida
// =====================================================

alineacionLongTriple = ema5 > ema8 and ema8 > ema13
alineacionShortTriple = ema5 < ema8 and ema8 < ema13

cruceLong = emaMode == "5/8/13" ? (alineacionLongTriple and not alineacionLongTriple[1]) : ta.crossover(emaFast, emaSlow)
cruceShort = emaMode == "5/8/13" ? (alineacionShortTriple and not alineacionShortTriple[1]) : ta.crossunder(emaFast, emaSlow)

// Retroceso: el precio toca la EMA rapida y rebota en la direccion de la tendencia
pullbackLong = estructuraLong and low <= emaFast and close > emaFast and close > open
pullbackShort = estructuraShort and high >= emaFast and close < emaFast and close < open

disparoLong = cruceLong or (usarRetroceso and pullbackLong)
disparoShort = cruceShort or (usarRetroceso and pullbackShort)

// =====================================================
// Confirmaciones (RSI ya NO bloquea por divergencia)
// =====================================================

rsiLongOk = rsi > 50 and rsiSlope > 0
rsiShortOk = rsi < 50 and rsiSlope < 0

wyckoffLongOk = esMarkup or rupturaAcumulacion
wyckoffShortOk = esMarkdown or rupturaDistribucion

estructuraLongOk = not exigirAbsorcion or divBull or absorcionBull
estructuraShortOk = not exigirAbsorcion or divBear or absorcionBear
manosFuertesLongOk = not exigirManosFuertes or manosFuertesLong
manosFuertesShortOk = not exigirManosFuertes or manosFuertesShort

longCandidate = barstate.isconfirmed and graficoEntradaOk and disparoLong and estructuraLong and rsiLongOk and wyckoffLongOk and fractalEntradaLongOk and not mercadoLateral and volOk and estructuraLongOk and manosFuertesLongOk
shortCandidate = barstate.isconfirmed and graficoEntradaOk and disparoShort and estructuraShort and rsiShortOk and wyckoffShortOk and fractalEntradaShortOk and not mercadoLateral and volOk and estructuraShortOk and manosFuertesShortOk

// =====================================================
// Gestion sugerida de riesgo (dinamica segun fuerza)
// =====================================================

slMultLong = tendenciaFuerteLong ? slFuerte : slDebil
tpMultLong = tendenciaFuerteLong ? tpFuerte : tpDebil
slMultShort = tendenciaFuerteShort ? slFuerte : slDebil
tpMultShort = tendenciaFuerteShort ? tpFuerte : tpDebil

slLong = close - atr * slMultLong
tpLong = close + atr * tpMultLong
slShort = close + atr * slMultShort
tpShort = close - atr * tpMultShort

rrLong = tendenciaFuerteLong ? "2x4" : "1x2"
rrShort = tendenciaFuerteShort ? "2x4" : "1x2"

dayTradingSyncInfo = dayTradingLongOk ? 1 : dayTradingShortOk ? -1 : 0
ema50Info = ema50LongOk ? 1 : ema50ShortOk ? -1 : 0
manosFuertesInfo = manosFuertesLong ? 1 : manosFuertesShort ? -1 : 0
graficoEntradaInfo = graficoEntradaOk ? 1 : 0

plot(longCandidate ? slLong : na, "SL_LONG", color=color.new(color.red, 100), display=display.data_window, editable=false)
plot(longCandidate ? tpLong : na, "TP_LONG", color=color.new(color.green, 100), display=display.data_window, editable=false)
plot(shortCandidate ? slShort : na, "SL_SHORT", color=color.new(color.red, 100), display=display.data_window, editable=false)
plot(shortCandidate ? tpShort : na, "TP_SHORT", color=color.new(color.green, 100), display=display.data_window, editable=false)
plot(longCandidate ? (tendenciaFuerteLong ? 2 : 1) : na, "FUERZA_LONG", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(shortCandidate ? (tendenciaFuerteShort ? 2 : 1) : na, "FUERZA_SHORT", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(dayTradingSyncInfo, "DAYTRADING_SYNC", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(sesgoD, "MACRO_1D", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(sesgoH1, "LUPA_1H", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(dirM5, "PISTOLA_5M", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(graficoEntradaInfo, "ENTRY_TF_OK", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(ema50Info, "EMA50_FILTER", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(manosFuertesInfo, "MANOS_FUERTES", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(rsi, "RSI_INFO", color=color.new(color.purple, 100), display=display.data_window, editable=false)
plot(ratioRangoAtr, "RATIO_RANGO_ATR", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(tfMin, "TF_MIN_AUTO", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(emaModeInfo, "EMA_MODE_AUTO", color=color.new(color.gray, 100), display=display.data_window, editable=false)
plot(rsiLen, "RSI_LEN_AUTO", color=color.new(color.gray, 100), display=display.data_window, editable=false)

// =====================================================
// Visualizacion: EMAs + cinta de tendencia
// =====================================================

pFast = plot(mostrarEmaOperativa ? emaFast : na, "EMA rapida", color=color.new(colorEmaRapida, transpEmaRapida), linewidth=grosorEmaRapida)
plot(mostrarEmaMedia and emaMode == "5/8/13" ? ema8 : na, "EMA media", color=color.new(colorEmaMedia, transpEmaMedia), linewidth=grosorEmaMedia)
pSlow = plot(mostrarEmaOperativa ? emaSlow : na, "EMA lenta", color=color.new(colorEmaLenta, transpEmaLenta), linewidth=grosorEmaLenta)
plot(mostrarEma50 ? ema50 : na, "EMA 50 filtro fuerte", color=color.new(colorEma50, transpEma50), linewidth=grosorEma50)
plot(mostrarEma200 ? ema200 : na, "EMA 200", color=color.new(colorEma200, transpEma200), linewidth=grosorEma200)

// Cinta: verde alcista / rojo bajista; mas opaca = FUERTE, mas tenue = DEBIL
cintaCol = not mostrarCinta or not mostrarEmaOperativa ? na : tendenciaFuerteLong ? color.new(color.green, 75) : tendenciaDebilLong ? color.new(color.green, 90) : tendenciaFuerteShort ? color.new(color.red, 75) : tendenciaDebilShort ? color.new(color.red, 90) : na
fill(pFast, pSlow, color=cintaCol, title="Cinta de tendencia")

zonaWyckoffCol = not mostrarZonasWyckoff ? na : esAcumulacion ? color.new(color.teal, 92) : esDistribucion ? color.new(color.orange, 92) : esMarkup ? color.new(color.green, 95) : esMarkdown ? color.new(color.red, 95) : na
bgcolor(zonaWyckoffCol, title="Zonas Wyckoff y contexto")

zonaWyckoffTxt = esAcumulacion ? "ACUM" : esDistribucion ? "DIST" : esMarkup ? "MARKUP" : esMarkdown ? "MARKDOWN" : ""
zonaWyckoffCambio = mostrarNombreZonaWyckoff and zonaWyckoffTxt != "" and zonaWyckoffTxt != zonaWyckoffTxt[1]
zonaWyckoffLabelCol = esAcumulacion ? color.new(color.teal, 18) : esDistribucion ? color.new(color.orange, 18) : esMarkup ? color.new(color.green, 18) : color.new(color.red, 18)

if zonaWyckoffCambio
    label.new(bar_index, high + atr * 1.1, zonaWyckoffTxt, style=label.style_label_down, textcolor=color.white, color=zonaWyckoffLabelCol, size=size.tiny)

// =====================================================
// Visualizacion: soporte / resistencia opcional
// =====================================================

var line[] lineasResistencia = array.new_line()
var line[] lineasSoporte = array.new_line()

srExisteCerca(array<line> lineas, float nivel, float distanciaMinima) =>
    existe = false
    if array.size(lineas) > 0
        for i = 0 to array.size(lineas) - 1
            lineaActual = array.get(lineas, i)
            existe := existe or math.abs(line.get_y1(lineaActual) - nivel) <= distanciaMinima
    existe

actualizarVisibilidadSr(array<line> lineas, color colorBase, float distanciaVisible) =>
    if array.size(lineas) > 0
        for i = 0 to array.size(lineas) - 1
            lineaActual = array.get(lineas, i)
            nivel = line.get_y1(lineaActual)
            visible = not mostrarSoloSrCercano or math.abs(close - nivel) <= distanciaVisible
            line.set_color(lineaActual, visible ? colorBase : color.new(colorBase, 100))

pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivotLow = ta.pivotlow(low, pivotLen, pivotLen)
distanciaMinimaSr = atr * distanciaMinimaSrAtr
distanciaVisibleSr = atr * distanciaSrVisibleAtr
colorResistenciaSr = color.new(color.red, 86)
colorSoporteSr = color.new(color.green, 86)

if mostrarSoporteResistencia and not na(pivotHigh) and not srExisteCerca(lineasResistencia, pivotHigh, distanciaMinimaSr)
    nuevaResistencia = line.new(bar_index - pivotLen, pivotHigh, bar_index, pivotHigh, extend=extend.right, color=colorResistenciaSr, style=line.style_solid, width=1)
    array.push(lineasResistencia, nuevaResistencia)
    if array.size(lineasResistencia) > maxLineasSR
        line.delete(array.shift(lineasResistencia))

if mostrarSoporteResistencia and not na(pivotLow) and not srExisteCerca(lineasSoporte, pivotLow, distanciaMinimaSr)
    nuevoSoporte = line.new(bar_index - pivotLen, pivotLow, bar_index, pivotLow, extend=extend.right, color=colorSoporteSr, style=line.style_solid, width=1)
    array.push(lineasSoporte, nuevoSoporte)
    if array.size(lineasSoporte) > maxLineasSR
        line.delete(array.shift(lineasSoporte))

if mostrarSoporteResistencia
    actualizarVisibilidadSr(lineasResistencia, colorResistenciaSr, distanciaVisibleSr)
    actualizarVisibilidadSr(lineasSoporte, colorSoporteSr, distanciaVisibleSr)

if not mostrarSoporteResistencia and (array.size(lineasResistencia) > 0 or array.size(lineasSoporte) > 0)
    while array.size(lineasResistencia) > 0
        line.delete(array.shift(lineasResistencia))
    while array.size(lineasSoporte) > 0
        line.delete(array.shift(lineasSoporte))

// =====================================================
// Visualizacion: señales, cruces, retrocesos y eventos
// =====================================================

modoCompacto = modoEtiquetas == "Compacto"
modoDetallado = modoEtiquetas == "Detallado"
modoSoloFlechas = modoEtiquetas == "Solo flechas"

plotshape(modoCompacto and longCandidate, title="LONG compacto", style=shape.labelup, location=location.belowbar, color=color.new(color.lime, 0), text="LONG", textcolor=color.white, size=size.normal)
plotshape(modoCompacto and shortCandidate, title="SHORT compacto", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="SHORT", textcolor=color.white, size=size.normal)
plotshape(modoSoloFlechas and longCandidate, title="LONG solo flecha", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), text="", size=size.normal)
plotshape(modoSoloFlechas and shortCandidate, title="SHORT solo flecha", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), text="", size=size.normal)

plotshape(mostrarCrucesEma and cruceLong, title="Cruce EMA alcista", style=shape.diamond, location=location.belowbar, color=color.new(color.aqua, 0), text="EMA+", textcolor=color.white, size=size.small)
plotshape(mostrarCrucesEma and cruceShort, title="Cruce EMA bajista", style=shape.diamond, location=location.abovebar, color=color.new(color.orange, 0), text="EMA-", textcolor=color.white, size=size.small)

plotshape(mostrarRetrocesos and pullbackLong, title="Retroceso alcista", style=shape.circle, location=location.belowbar, color=color.new(color.green, 15), text="PB+", textcolor=color.white, size=size.tiny)
plotshape(mostrarRetrocesos and pullbackShort, title="Retroceso bajista", style=shape.circle, location=location.abovebar, color=color.new(color.red, 15), text="PB-", textcolor=color.white, size=size.tiny)

plotshape(mostrarFractalidadDayTrading and dayTradingLongOk and not dayTradingLongOk[1], title="Sincronia day trading alcista 1D/1H/5m", style=shape.flag, location=location.belowbar, color=color.new(color.green, 0), text="DT+", textcolor=color.white, size=size.small)
plotshape(mostrarFractalidadDayTrading and dayTradingShortOk and not dayTradingShortOk[1], title="Sincronia day trading bajista 1D/1H/5m", style=shape.flag, location=location.abovebar, color=color.new(color.red, 0), text="DT-", textcolor=color.white, size=size.small)

plotshape(mostrarManosFuertes and manosFuertesLong, title="Manos fuertes alcistas", style=shape.square, location=location.belowbar, color=color.new(color.aqua, 0), text="MF+", textcolor=color.white, size=size.tiny)
plotshape(mostrarManosFuertes and manosFuertesShort, title="Manos fuertes bajistas", style=shape.square, location=location.abovebar, color=color.new(color.fuchsia, 0), text="MF-", textcolor=color.white, size=size.tiny)

plotshape(mostrarDivergencias and divBull and not mostrarTextoDivAbsOverlay ? low - atr * 0.45 : na, title="Divergencia alcista", style=shape.triangleup, location=location.absolute, color=color.new(color.green, 15), size=size.tiny)
plotshape(mostrarDivergencias and divBear and not mostrarTextoDivAbsOverlay ? high + atr * 0.45 : na, title="Divergencia bajista", style=shape.triangledown, location=location.absolute, color=color.new(color.red, 15), size=size.tiny)
plotshape(mostrarAbsorciones and absorcionBull and not mostrarTextoDivAbsOverlay ? low - atr * 0.75 : na, title="Absorcion alcista", style=shape.circle, location=location.absolute, color=color.new(color.aqua, 15), size=size.tiny)
plotshape(mostrarAbsorciones and absorcionBear and not mostrarTextoDivAbsOverlay ? high + atr * 0.75 : na, title="Absorcion bajista", style=shape.circle, location=location.absolute, color=color.new(color.fuchsia, 15), size=size.tiny)
plotshape(mostrarDivergencias and divBull and mostrarTextoDivAbsOverlay ? low - atr * 0.45 : na, title="Divergencia alcista texto", style=shape.triangleup, location=location.absolute, color=color.new(color.green, 15), text="DIV+", textcolor=color.white, size=size.tiny)
plotshape(mostrarDivergencias and divBear and mostrarTextoDivAbsOverlay ? high + atr * 0.45 : na, title="Divergencia bajista texto", style=shape.triangledown, location=location.absolute, color=color.new(color.red, 15), text="DIV-", textcolor=color.white, size=size.tiny)
plotshape(mostrarAbsorciones and absorcionBull and mostrarTextoDivAbsOverlay ? low - atr * 0.75 : na, title="Absorcion alcista texto", style=shape.circle, location=location.absolute, color=color.new(color.aqua, 15), text="ABS+", textcolor=color.white, size=size.tiny)
plotshape(mostrarAbsorciones and absorcionBear and mostrarTextoDivAbsOverlay ? high + atr * 0.75 : na, title="Absorcion bajista texto", style=shape.circle, location=location.absolute, color=color.new(color.fuchsia, 15), text="ABS-", textcolor=color.white, size=size.tiny)

if modoDetallado and longCandidate
    label.new(bar_index, low, "LONG " + (tendenciaFuerteLong ? "FUERTE" : "DEBIL") + " (" + rrLong + ")\nDayTrading: " + dayTradingDireccion + "\nFase: " + fase + "\nSL: " + str.tostring(slLong, "#.##") + "  TP: " + str.tostring(tpLong, "#.##"), style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 0), size=size.small)

if modoDetallado and shortCandidate
    label.new(bar_index, high, "SHORT " + (tendenciaFuerteShort ? "FUERTE" : "DEBIL") + " (" + rrShort + ")\nDayTrading: " + dayTradingDireccion + "\nFase: " + fase + "\nSL: " + str.tostring(slShort, "#.##") + "  TP: " + str.tostring(tpShort, "#.##"), style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0), size=size.small)

// =====================================================
// Panel day trading operativo
// =====================================================

var table panel = table.new(position.top_right, 2, 10, border_width=1, frame_color=color.new(color.gray, 50), frame_width=1)

planTxt = not graficoEntradaOk ? "CAMBIAR A 5m" : dayTradingLongOk ? "BUSCAR LONG 5m" : dayTradingShortOk ? "BUSCAR SHORT 5m" : "ESPERAR"
planCol = not graficoEntradaOk ? color.new(color.orange, 0) : dayTradingLongOk ? color.new(color.green, 0) : dayTradingShortOk ? color.new(color.red, 0) : color.new(color.orange, 0)
comentarioDayTrading = not graficoEntradaOk ? "La pistola se valida en 5m" : dayTradingLongOk ? "Macro+lupa+pistola alcistas" : dayTradingShortOk ? "Macro+lupa+pistola bajistas" : macroShortOk and lupaShortOk and not pistolaShortOk ? "Esperar gatillo short 5m" : macroLongOk and lupaLongOk and not pistolaLongOk ? "Esperar gatillo long 5m" : macroShortOk and lupaLongOk ? "1H rebota contra macro bajista" : macroLongOk and lupaShortOk ? "1H corrige contra macro alcista" : "Sin alineacion: no forzar"
comentarioCol = dayTradingLongOk ? color.new(color.green, 0) : dayTradingShortOk ? color.new(color.red, 0) : color.new(color.gray, 0)
ema50Txt = ema50LongOk ? "ALCISTA" : ema50ShortOk ? "BAJISTA" : "NEUTRA"
ema50Col = ema50LongOk ? color.new(color.green, 0) : ema50ShortOk ? color.new(color.red, 0) : color.new(color.gray, 0)
rsiTxt = str.tostring(rsi, "#.##") + " | " + rsiLectura(rsi)
rsiCol = rsi >= 70 ? color.new(color.orange, 0) : rsi <= 30 ? color.new(color.orange, 0) : rsi > 55 ? color.new(color.green, 0) : rsi < 45 ? color.new(color.red, 0) : color.new(color.gray, 0)
graficoTxt = esGraficoEntrada5m ? "5m OK" : fmtTf(tfMin) + " | usar 5m"
graficoCol = esGraficoEntrada5m ? color.new(color.green, 0) : color.new(color.orange, 0)

if mostrarPanel and barstate.islast
    table.cell(panel, 0, 0, "DAYTRADING", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(panel, 1, 0, "1D macro | 1H lupa | 5m pistola", text_color=color.white, bgcolor=color.new(color.blue, 0), text_size=size.small)
    table.cell(panel, 0, 1, "Plan", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 1, planTxt, text_color=color.white, bgcolor=planCol, text_size=size.small)
    table.cell(panel, 0, 2, "Comentario", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 2, comentarioDayTrading, text_color=color.white, bgcolor=comentarioCol, text_size=size.small)
    table.cell(panel, 0, 3, "Macro 1D", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 3, fmtSesgo(sesgoD), text_color=color.white, bgcolor=colorSesgo(sesgoD), text_size=size.small)
    table.cell(panel, 0, 4, "Lupa 1H", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 4, fmtSesgo(sesgoH1), text_color=color.white, bgcolor=colorSesgo(sesgoH1), text_size=size.small)
    table.cell(panel, 0, 5, "Pistola 5m", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 5, fmtSesgo(sesgoM5), text_color=color.white, bgcolor=colorSesgo(sesgoM5), text_size=size.small)
    table.cell(panel, 0, 6, "Grafico", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 6, graficoTxt, text_color=color.white, bgcolor=graficoCol, text_size=size.small)
    table.cell(panel, 0, 7, "EMA50", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 7, ema50Txt, text_color=color.white, bgcolor=ema50Col, text_size=size.small)
    table.cell(panel, 0, 8, "RSI", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 8, rsiTxt, text_color=color.white, bgcolor=rsiCol, text_size=size.small)
    table.cell(panel, 0, 9, "Wyckoff", text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)
    table.cell(panel, 1, 9, faseOperativa, text_color=color.white, bgcolor=color.new(color.black, 30), text_size=size.small)

// =====================================================
// Alertas JSON para webhook
// =====================================================

alertcondition(longCandidate, title="Alerta LONG Wyckoff EMA RSI v2.6 DayTrading", message="{\"event_type\":\"signal.long_candidate\",\"signal\":\"LONG\",\"trend\":\"ALCISTA\",\"strength\":\"{{plot(\"FUERZA_LONG\")}}\",\"daytrading_sync\":\"{{plot(\"DAYTRADING_SYNC\")}}\",\"macro_1d\":\"{{plot(\"MACRO_1D\")}}\",\"lupa_1h\":\"{{plot(\"LUPA_1H\")}}\",\"pistola_5m\":\"{{plot(\"PISTOLA_5M\")}}\",\"entry_tf_ok\":\"{{plot(\"ENTRY_TF_OK\")}}\",\"ema50_filter\":\"{{plot(\"EMA50_FILTER\")}}\",\"strong_hands\":\"{{plot(\"MANOS_FUERTES\")}}\",\"symbol\":\"{{ticker}}\",\"timeframe\":\"{{interval}}\",\"price\":\"{{close}}\",\"sl\":\"{{plot(\"SL_LONG\")}}\",\"tp\":\"{{plot(\"TP_LONG\")}}\",\"source_module\":\"tradingview.indicador_wyckoff_ema_rsi_v2\",\"severity\":\"info\",\"reason\":\"wyckoff_ema_rsi_daytrading_1d_1h_5m_long\"}")
alertcondition(shortCandidate, title="Alerta SHORT Wyckoff EMA RSI v2.6 DayTrading", message="{\"event_type\":\"signal.short_candidate\",\"signal\":\"SHORT\",\"trend\":\"BAJISTA\",\"strength\":\"{{plot(\"FUERZA_SHORT\")}}\",\"daytrading_sync\":\"{{plot(\"DAYTRADING_SYNC\")}}\",\"macro_1d\":\"{{plot(\"MACRO_1D\")}}\",\"lupa_1h\":\"{{plot(\"LUPA_1H\")}}\",\"pistola_5m\":\"{{plot(\"PISTOLA_5M\")}}\",\"entry_tf_ok\":\"{{plot(\"ENTRY_TF_OK\")}}\",\"ema50_filter\":\"{{plot(\"EMA50_FILTER\")}}\",\"strong_hands\":\"{{plot(\"MANOS_FUERTES\")}}\",\"symbol\":\"{{ticker}}\",\"timeframe\":\"{{interval}}\",\"price\":\"{{close}}\",\"sl\":\"{{plot(\"SL_SHORT\")}}\",\"tp\":\"{{plot(\"TP_SHORT\")}}\",\"source_module\":\"tradingview.indicador_wyckoff_ema_rsi_v2\",\"severity\":\"info\",\"reason\":\"wyckoff_ema_rsi_daytrading_1d_1h_5m_short\"}")
